# Prompt Engineering Lab — Environment Variables
# Copy to .env and edit as needed

# Backend: "ollama" (default) | "ec2" | "openai"
LLM_BACKEND=ollama

# Ollama (local — default)
OLLAMA_URL=http://localhost:11434/v1

# EC2 (remote GPU — optional)
# EC2_URL=http://YOUR-EC2-IP:11434/v1

# OpenAI (cloud API — optional)
# OPENAI_API_KEY=sk-...

# Default model
DEFAULT_MODEL=llama3.1:8b

