# Prompt Engineering Lab — Environment Variables
# Copy to .env and edit as needed
#
# Just set LLM_BACKEND and the required variable(s) for that backend.
# Default is "ollama" — works out of the box with a local Ollama install.

# ═══ Backend Selection ═══
# Choose one: "ollama" | "ec2" | "openai" | "gemini"
LLM_BACKEND=ollama

# ═══ Default Model ═══
# Change this to match your chosen backend
DEFAULT_MODEL=llama3.1:8b

# ═══ Ollama (local — default, no config needed) ═══
# OLLAMA_URL=http://localhost:11434/v1

# ═══ EC2 (remote GPU) ═══
# EC2_URL=http://YOUR-EC2-IP:11434/v1

# ═══ OpenAI (cloud API) ═══
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...
# DEFAULT_MODEL=gpt-4o-mini

# ═══ Gemini (Google API) ═══
# Get a key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# DEFAULT_MODEL=gemini-flash-latest
